DJANGO_SECRET_KEY=change-this-in-production
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

DB_ENGINE=django.db.backends.postgresql
DB_NAME=plprs_db
DB_USER=plprs_user
DB_PASSWORD=strong_password
DB_HOST=localhost
DB_PORT=5432
# Render uses one connection string instead of the DB_* values above.
# DATABASE_URL=postgresql://user:password@host:5432/database

TIME_ZONE=Asia/Kolkata

# Keep False on small/free hosting plans. Set True only when the server has
# enough memory for scikit-learn, NumPy, and spaCy imports at request time.
PLPRS_ENABLE_ML_LIBS=False
